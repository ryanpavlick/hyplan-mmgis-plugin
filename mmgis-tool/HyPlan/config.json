    "name": "HyPlan",
    "toolbarPriority": 900,
    "paths": {
        "HyPlanTool": "essence/Tools/HyPlan/HyPlanTool"
    },
    "expandable": true,
    "config": {
        "rows": [
            {
                "name": "HyPlan Service",
                "components": [
                    {
                        "field": "variables.serviceUrl",
                        "name": "Service URL",
                        "description": "URL of the HyPlan service API",
                        "type": "text",
                        "width": 6,
                        "default": "http://localhost:8100"
                    }
                ]
            }
        ]
    }
}
