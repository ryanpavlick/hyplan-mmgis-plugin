{
    "defaultIcon": "airplane",
    "description": "Flight line planning with HyPlan.",
    "descriptionFull": {
        "title": "The HyPlan tool generates flight lines from drawn polygons, optimizes line ordering, computes flight plans, and exports to KML/GPX."
    },
